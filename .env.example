# ===========================================
# ШАБЛОН КОНФИГУРАЦИИ (без реальных токенов)
# ===========================================
# Скопируйте этот файл в .env и заполните своими значениями
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)

# ===========================================
# Telegram Bot Token
# ===========================================
# Получить в @BotFather (https://t.me/BotFather)
# 1. /newbot - создать бота
# 2. Скопировать токен
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ===========================================
# Yandex Maps API Key
# ===========================================
# Получить в Яндекс.Кабинет разработчика
# https://developer.tech.yandex.ru/
# Подключить: HTTP Геокодер + Статические карты
YANDEX_API_KEY=YOUR_YANDEX_API_KEY_HERE

# ===========================================
# Proxy URL (для обхода блокировок в РФ)
# ===========================================
# Формат: http://host:port или socks5://user:pass@host:port
# Пример: http://proxy.company.lan:3128
# Если не нужен - закомментировать или удалить
PROXY_URL=http://your-proxy-host:port

# ===========================================
# Map Base URL
# ===========================================
# Для локальной разработки:
MAP_BASE_URL=http://localhost:8000

# Для GitHub Pages (после деплоя):
# MAP_BASE_URL=https://username.github.io/repo-name

# Для Vercel/Netlify:
# MAP_BASE_URL=https://your-app.vercel.app
